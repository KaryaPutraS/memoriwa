# MemoriWA configuration — install.sh generates this file for you.
# Copy to .env and fill in real values for a manual install.

# Public URL of the dashboard, as users open it in the browser
PUBLIC_URL=http://your-domain-or-ip
# Host port the dashboard is served on
WEB_PORT=80

# Dashboard login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-something-strong

# Secrets — generate with: openssl rand -hex 32 (16 for the others)
JWT_SECRET=please-generate-64-hex-chars
WEBHOOK_SECRET=please-generate-32-hex-chars
WAHA_API_KEY=please-generate-32-hex-chars

# Optional fallback AI key for OCR/identity (can also be set in the dashboard)
GROQ_API_KEY=
