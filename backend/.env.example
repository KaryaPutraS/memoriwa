# Environment: production | dev | development | test
ENV=dev

# Auth — MUST be set and strong in production
JWT_SECRET=replace-with-a-random-32-byte-secret-minimum
WEBHOOK_SECRET=replace-with-a-webhook-secret-minimum-16-chars

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password

# CORS — comma-separated origins (required in production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MongoDB (optional — uses in-memory store if unset or unreachable)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=wa_dashboard

# Rate limiting
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX=200

# Body size protection (default: 5 MB)
MAX_BODY_SIZE_BYTES=5242880

# Docs — set to true/1/yes to enable Swagger UI at /docs
ENABLE_DOCS=false
